# Environment Configuration Template

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application Environment
# Determines the runtime environment and enables/disables certain features
# Values: development, staging, production
# Default: development
NODE_ENV=development

# Application Base URL
# The base URL where the application will be hosted
# Used for absolute URLs, API calls, and routing
# Example: https://myapp.com, http://localhost:5173
# Default: http://localhost:5173
VITE_APP_BASE_URL=http://localhost:5173

# Application Name
# Used in page titles, meta tags, and branding
# Default: Enhanced Visual Design
VITE_APP_NAME="Enhanced Visual Design"

# Application Version
# Semantic version of the application
# Used for cache busting and version display
# Default: 1.0.0
VITE_APP_VERSION=1.0.0

# =============================================================================
# API CONFIGURATION
# =============================================================================

# API Base URL
# The base URL for all API requests
# Should include protocol and domain, no trailing slash
# Example: https://api.myapp.com, http://localhost:3001/api
# Default: http://localhost:3001/api
VITE_API_BASE_URL=http://localhost:3001/api

# API Timeout
# Request timeout in milliseconds
# Default: 10000 (10 seconds)
VITE_API_TIMEOUT=10000

# API Key
# Public API key for client-side requests (if required)
# Note: Never put sensitive keys here - use server-side environment for those
# Example: pk_live_abc123def456ghi789
VITE_API_KEY=your_public_api_key_here

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================

# JWT Secret (Server-side only - not prefixed with VITE_)
# Used for signing and verifying JWT tokens
# Should be a long, random string
# Example: your-super-secret-jwt-key-here-make-it-long-and-random
JWT_SECRET=your-super-secret-jwt-key-here

# JWT Expiration
# How long JWT tokens remain valid
# Format: time string (e.g., '1h', '7d', '30m')
# Default: 24h
JWT_EXPIRES_IN=24h

# OAuth Configuration (if using social login)
# Google OAuth Client ID
# Get from Google Cloud Console
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# GitHub OAuth Client ID
# Get from GitHub Developer Settings
VITE_GITHUB_CLIENT_ID=your_github_client_id_here

# =============================================================================
# DATABASE CONFIGURATION (Server-side only)
# =============================================================================

# Database URL
# Full connection string for your database
# Examples:
# PostgreSQL: postgresql://username:password@localhost:5432/database_name
# MySQL: mysql://username:password@localhost:3306/database_name
# MongoDB: mongodb://username:password@localhost:27017/database_name
DATABASE_URL=postgresql://username:password@localhost:5432/myapp_development

# Database Pool Configuration
# Maximum number of database connections in the pool
# Default: 10
DB_POOL_MAX=10

# Minimum number of database connections in the pool
# Default: 2
DB_POOL_MIN=2

# =============================================================================
# THIRD-PARTY SERVICES
# =============================================================================

# Analytics Configuration
# Google Analytics Measurement ID
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry Configuration (Error Tracking)
# Sentry DSN for error reporting
# Get from Sentry project settings
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Email Service Configuration (Server-side only)
# SMTP Configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SendGrid API Key (alternative to SMTP)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# File Upload Configuration
# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AWS S3 Configuration (alternative to Cloudinary)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Development Server Configuration
# Port for the development server
# Default: 5173
VITE_DEV_PORT=5173

# Enable/disable development features
# Values: true, false
# Default: true in development
VITE_DEV_TOOLS=true

# Hot Module Replacement
# Enable/disable HMR in development
# Values: true, false
# Default: true
VITE_HMR=true

# Source Maps
# Enable source maps for debugging
# Values: true, false
# Default: true in development
VITE_SOURCE_MAPS=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Feature toggles for enabling/disabling features
# Values: true, false

# Enable dark mode toggle
VITE_FEATURE_DARK_MODE=true

# Enable user registration
VITE_FEATURE_USER_REGISTRATION=true

# Enable social login
VITE_FEATURE_SOCIAL_LOGIN=false

# Enable analytics tracking
VITE_FEATURE_ANALYTICS=true

# Enable error reporting
VITE_FEATURE_ERROR_REPORTING=true

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS Configuration (Server-side only)
# Allowed origins for CORS requests
# Comma-separated list of origins
# Example: http://localhost:3000,https://myapp.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
# Maximum requests per window
RATE_LIMIT_MAX=100

# Rate limiting window in minutes
RATE_LIMIT_WINDOW=15

# Content Security Policy
# Enable/disable CSP headers
# Values: true, false
# Default: true in production
CSP_ENABLED=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Level
# Controls the verbosity of logging
# Values: error, warn, info, debug
# Default: info
LOG_LEVEL=info

# Log Format
# Format for log output
# Values: json, simple
# Default: json in production, simple in development
LOG_FORMAT=simple

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Cache Configuration
# Enable/disable caching
# Values: true, false
# Default: true
CACHE_ENABLED=true

# Cache TTL in seconds
# Default: 3600 (1 hour)
CACHE_TTL=3600

# Bundle Analysis
# Enable bundle analysis in build
# Values: true, false
# Default: false
VITE_ANALYZE_BUNDLE=false

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

# Health Check Configuration
# Enable health check endpoint
# Values: true, false
# Default: true
HEALTH_CHECK_ENABLED=true

# Metrics Collection
# Enable metrics collection
# Values: true, false
# Default: true in production
METRICS_ENABLED=true

# =============================================================================
# NOTES AND SECURITY CONSIDERATIONS
# =============================================================================

# IMPORTANT SECURITY NOTES:
# 1. Never commit this file with real values to version control
# 2. Use different values for each environment (dev, staging, prod)
# 3. Variables prefixed with VITE_ are exposed to the client-side code
# 4. Server-side secrets should NOT be prefixed with VITE_
# 5. Use strong, unique passwords and API keys
# 6. Regularly rotate secrets and API keys
# 7. Use environment-specific configuration management in production

# SETUP INSTRUCTIONS:
# 1. Copy this file to .env in your project root
# 2. Replace all placeholder values with your actual configuration
# 3. Add .env to your .gitignore file
# 4. For production, use your hosting platform's environment variable system
# 5. Validate all URLs and credentials before deployment

# VALIDATION CHECKLIST:
# □ All required variables are set
# □ URLs are valid and accessible
# □ API keys are correct and have proper permissions
# □ Database connection string is valid
# □ CORS origins include your frontend domain
# □ JWT secret is long and random
# □ File upload service is configured
# □ Email service is configured and tested